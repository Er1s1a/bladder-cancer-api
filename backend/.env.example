# 微信小程序 AppID
WECHAT_APPID=wx_your_appid_here
# 微信小程序 AppSecret
WECHAT_SECRET=your_secret_here

# 数据库连接
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/bladder_cancer

# JWT 密钥（生产环境请用随机字符串）
JWT_SECRET=change_me_to_a_random_string_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=30

# 服务端口
PORT=8000
